# ===========================================
# FORO CIUDADANO - Backend Environment
# ===========================================
# Copiar a .env y completar valores

# ===========================================
# DATABASE (Prisma)
# ===========================================
# Local: postgresql://user:pass@localhost:5432/dbname
# Railway: Proveído automáticamente por Railway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foro_ciudadano

# ===========================================
# REDIS (Caching/Sessions)
# ===========================================
# Local (sin Docker): redis://localhost:6379
# Railway: Proveído automáticamente (Redis plugin)
# Railway usa REDIS_URL automáticamente
REDIS_URL=redis://localhost:6379

# ===========================================
# MIGRATIONS (optional)
# ===========================================
# Set to 'true' to run migrations + seed on startup
# Default: 'false' (en production Railway)
RUN_MIGRATIONS=false

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ===========================================
# SERVER
# ===========================================
NODE_ENV=development
PORT=3001

# ===========================================
# CORS
# ===========================================
# Desarrollo: http://localhost:3000
# Producción: URL del frontend en Railway
ALLOWED_ORIGINS=http://localhost:3000

# ===========================================
# ADMIN INITIAL (development)
# ===========================================
# Override admin credentials in seed
# ADMIN_EMAIL=admin@eventpass.com
# ADMIN_PASSWORD=Admin1234!
# PONENTE_EMAIL=ponente@eventpass.com
# PONENTE_PASSWORD=Ponente1234!