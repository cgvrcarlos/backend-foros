// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  NO_DICE
}

enum GradoEstudios {
  PRIMARIA
  SECUNDARIA
  PREPARATORIA
  LICENCIATURA
  POSGRADO
  OTRO
}

enum SituacionLaboral {
  ESTUDIANTE
  EMPLEADO
  AUTOEMPLEADO
  DESEMPLEADO
  OTRO
}

enum TipoAsistencia {
  PRESENCIAL
  VIRTUAL
}

enum QuestionType {
  OPCION_UNICA
  MULTIPLE
  ESCALA
  ABIERTA_CORTO
  ABIERTA_LARGO
}

enum Seccion {
  ANALISIS
  PROPUESTAS
}

enum AdminRole {
  ADMIN
  PONENTE
}

// =============================================================================
// MODELS
// =============================================================================

// Usuario/Asistente del evento
model User {
  id               String           @id @default(cuid())
  apaterno         String
  amaterno         String
  nombres          String
  email            String           @unique
  telefono         String
  redesSociales    String?
  calle            String
  colonia          String
  cp               String
  municipio        String
  genero           Genero
  ocupacion        String
  gradoEstudios    GradoEstudios
  escuela          String?
  situacionLaboral SituacionLaboral
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  attendances Attendance[]
  responses   Response[]

  @@index([email])
}

// Administrador del sistema
model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  nombre    String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())

  @@index([email])
}

// Ponente (speaker del evento)
model Ponente {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  nombre    String
  bio       String?
  createdAt DateTime   @default(now())

  // Relations
  ponencias Ponencia[]

  @@index([email])
}

// Itinerario: relación entre ponente y evento
model Ponencia {
  id         String   @id @default(cuid())
  ponenteId  String
  eventoId   String
  lugar      String
  horaInicio String
  horaFin    String
  orden      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  ponente Ponente @relation(fields: [ponenteId], references: [id], onDelete: Cascade)
  evento  Event   @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@index([eventoId])
}

// Evento del calendario
model Event {
  id                  String   @id @default(cuid())
  titulo              String
  descripcion         String?
  fechaHora           DateTime
  linkVirtual         String?
  ubicacionPresencial String?
  publicado           Boolean  @default(false)
  eliminado           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  attendances Attendance[]
  survey      Survey?
  ponencias   Ponencia[]

  @@index([publicado, eliminado])
  @@index([fechaHora])
}

// Encuesta asociada a un evento
model Survey {
  id        String   @id @default(cuid())
  eventId   String   @unique
  titulo    String   @default("Encuesta de satisfacción")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions Question[]
  responses Response[]
}

// Pregunta dentro de una encuesta
model Question {
  id          String       @id @default(cuid())
  surveyId    String
  tipo        QuestionType
  texto       String
  opciones    String[]
  escalaMin   Int?
  escalaMax   Int?
  esRequerida Boolean      @default(false)
  seccion     Seccion      @default(ANALISIS)
  orden       Int          @default(0)
  createdAt   DateTime     @default(now())

  // Relations
  survey  Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([surveyId, orden])
}

// Confirmación de asistencia
model Attendance {
  id             String         @id @default(cuid())
  userId         String
  eventId        String
  tipoAsistencia TipoAsistencia @default(PRESENCIAL)
  qrCode         String         @unique
  confirmedAt    DateTime       @default(now())

  // Relations
  user     User      @relation(fields: [userId], references: [id])
  event    Event     @relation(fields: [eventId], references: [id])
  response Response?

  @@unique([userId, eventId])
  @@index([eventId, confirmedAt])
}

// Respuesta completa de encuesta
model Response {
  id           String   @id @default(cuid())
  attendanceId String   @unique
  surveyId     String
  userId       String
  submittedAt  DateTime @default(now())

  // Relations
  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  survey     Survey     @relation(fields: [surveyId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  answers    Answer[]

  @@index([surveyId, submittedAt])
}

// Respuesta individual a una pregunta
model Answer {
  id         String @id @default(cuid())
  responseId String
  questionId String
  respuesta  Json

  // Relations
  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([responseId, questionId])
}
