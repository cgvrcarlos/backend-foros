// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  NO_DICE
}

enum GradoEstudios {
  PRIMARIA
  SECUNDARIA
  PREPARATORIA
  LICENCIATURA
  POSGRADO
  OTRO
}

enum SituacionLaboral {
  ESTUDIANTE
  EMPLEADO
  AUTOEMPLEADO
  DESEMPLEADO
  OTRO
}

enum TipoAsistencia {
  PRESENCIAL
  VIRTUAL
}

enum QuestionType {
  OPCION_UNICA
  MULTIPLE
  ESCALA
  ABIERTA_CORTO
  ABIERTA_LARGO
}

enum Seccion {
  ANALISIS
  PROPUESTAS
}

enum Role {
  ADMIN
  PONENTE
  ASISTENTE
}

enum AdminLevel {
  STANDARD
  SUPER
}

// =============================================================================
// IDENTITY
// =============================================================================

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  nombre    String
  apaterno  String?
  amaterno  String?
  telefono  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // role assignments
  roles AccountRole[]

  // 0..1 profile per role (present iff role is assigned)
  userProfile    UserProfile?
  ponenteProfile PonenteProfile?
  adminProfile   AdminProfile?

  // domain relations
  attendances Attendance[]
  responses   Response[]
  ponencias   Ponencia[]

  @@index([email])
}

model AccountRole {
  accountId String
  role      Role
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([accountId, role])
  @@index([role])
  @@index([accountId])
}

// =============================================================================
// PROFILES (one row per role-when-present)
// =============================================================================

model UserProfile {
  accountId        String           @id
  apaterno         String
  amaterno         String
  nombres          String
  genero           Genero
  ocupacion        String
  gradoEstudios    GradoEstudios
  escuela          String?
  situacionLaboral SituacionLaboral
  direccion        Json?
  redesSociales    Json?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PonenteProfile {
  accountId     String  @id
  bio           String?
  especialidad  String?
  fotoUrl       String?
  redesSociales Json?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  accountId String     @id
  nivel     AdminLevel @default(STANDARD)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// =============================================================================
// DOMAIN (re-wired to Account)
// =============================================================================

// Itinerario: relación entre ponente (Account) y evento
model Ponencia {
  id          String   @id @default(cuid())
  ponenteId   String
  eventoId    String
  titulo      String
  descripcion String?
  lugar       String
  horaInicio  DateTime @db.Time(0)
  horaFin     DateTime @db.Time(0)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ponente Account @relation(fields: [ponenteId], references: [id], onDelete: Cascade)
  evento  Event   @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@index([eventoId])
  @@index([ponenteId])
}

// Evento del calendario
model Event {
  id                  String   @id @default(cuid())
  titulo              String
  descripcion         String?
  fechaHora           DateTime
  linkVirtual         String?
  ubicacionPresencial String?
  publicado           Boolean  @default(false)
  eliminado           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  attendances Attendance[]
  survey      Survey?
  ponencias   Ponencia[]

  @@index([publicado, eliminado])
  @@index([fechaHora])
}

// Encuesta asociada a un evento
model Survey {
  id        String   @id @default(cuid())
  eventId   String   @unique
  titulo    String   @default("Encuesta de satisfacción")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions Question[]
  responses Response[]
}

// Pregunta dentro de una encuesta
model Question {
  id          String       @id @default(cuid())
  surveyId    String
  tipo        QuestionType
  texto       String
  opciones    String[]
  escalaMin   Int?
  escalaMax   Int?
  esRequerida Boolean      @default(false)
  seccion     Seccion      @default(ANALISIS)
  orden       Int          @default(0)
  createdAt   DateTime     @default(now())

  // Relations
  survey  Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([surveyId, orden])
}

// Confirmación de asistencia
model Attendance {
  id             String         @id @default(cuid())
  userId         String
  eventId        String
  tipoAsistencia TipoAsistencia @default(PRESENCIAL)
  qrCode         String         @unique
  confirmedAt    DateTime       @default(now())

  // Relations
  account  Account   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event    Event     @relation(fields: [eventId], references: [id])
  response Response?

  @@unique([userId, eventId])
  @@index([eventId, confirmedAt])
  @@index([userId])
}

// Respuesta completa de encuesta
model Response {
  id           String   @id @default(cuid())
  attendanceId String   @unique
  surveyId     String
  userId       String
  submittedAt  DateTime @default(now())

  // Relations
  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  survey     Survey     @relation(fields: [surveyId], references: [id])
  account    Account    @relation(fields: [userId], references: [id])
  answers    Answer[]

  @@index([surveyId, submittedAt])
  @@index([userId])
}

// Respuesta individual a una pregunta
model Answer {
  id         String @id @default(cuid())
  responseId String
  questionId String
  answer     Json

  // Relations
  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([responseId, questionId])
}
